<Window
    Icon="/Resources/avalonia-logo.ico"
    Title="{Binding WindowTitle}"
    d:DesignHeight="920"
    d:DesignWidth="1280"
    mc:Ignorable="d"
    x:Class="TrailMealsPlanner.Desktop.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TrailMealsPlanner.Desktop.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnDefinitions="260,*" Margin="16">
        <Border Grid.Column="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="18"
                Padding="20">
            <StackPanel Spacing="12">
                <TextBlock FontSize="28" FontWeight="Bold" Text="TrailMealsPlanner" />
                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="Простая shell-навигация по основным экранам приложения." />

                <Button Command="{Binding ShowRationsCommand}" Content="Список рационов" HorizontalAlignment="Stretch" />
                <Button Command="{Binding ShowRationDetailsCommand}" Content="Детали рациона" HorizontalAlignment="Stretch" />
                <Button Command="{Binding ShowProductsCommand}" Content="Справочник продуктов" HorizontalAlignment="Stretch" />
                <Button Command="{Binding ShowDishesCommand}" Content="Справочник блюд" HorizontalAlignment="Stretch" />
                <Button Command="{Binding ShowPreferencesCommand}" Content="Участники / предпочтения" HorizontalAlignment="Stretch" />
                <Button Command="{Binding ShowTemplatesCommand}" Content="Шаблоны дней" HorizontalAlignment="Stretch" />
                <Button Command="{Binding ShowSettingsCommand}" Content="Настройки" HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="24,0,0,0"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                CornerRadius="18"
                Padding="20">
            <StackPanel Spacing="16">
                <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding CurrentScreenTitle}" />
                <ContentControl Content="{Binding CurrentScreen}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

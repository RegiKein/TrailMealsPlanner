<UserControl
    x:Class="TrailMealsPlanner.Desktop.Views.DishCatalogView"
    x:DataType="vm:DishCatalogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TrailMealsPlanner.Desktop.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d">

    <Grid ColumnDefinitions="420,*">
        <Border Grid.Column="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="18"
                Padding="24">
            <StackPanel Spacing="16">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="28" FontWeight="Bold" Text="Блюда" />
                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                               Opacity="0.95"
                               Text="Создайте блюдо как композицию продуктов и сразу увидьте сводное КБЖУ."
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Название блюда" />
                    <TextBox Text="{Binding Name}" Watermark="Например, овсянка с сухофруктами" />
                </StackPanel>

                <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                        CornerRadius="14"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ингредиенты" />

                        <StackPanel Spacing="8">
                            <TextBlock Text="Продукт" />
                            <ComboBox ItemsSource="{Binding AvailableProducts}"
                                      SelectedItem="{Binding SelectedProduct}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProductListItemViewModel">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" />
                                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="12"
                                                       Opacity="0.95"
                                                       Text="{Binding Summary}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Вес, г" />
                            <NumericUpDown Minimum="1" Maximum="5000" Increment="10" Value="{Binding IngredientWeight}" />
                        </StackPanel>

                        <Button Command="{Binding AddIngredientCommand}"
                                Content="Добавить ингредиент"
                                HorizontalAlignment="Stretch" />

                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="12"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Состав блюда" />
                                <ItemsControl ItemsSource="{Binding SelectedIngredients}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DishIngredientSelectionViewModel">
                                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*">
                    <Button Command="{Binding CreateDishCommand}"
                            Content="Создать блюдо"
                            HorizontalAlignment="Stretch" />
                    <Button Grid.Column="1"
                            Margin="12,0,0,0"
                            Command="{Binding RefreshCommand}"
                            Content="Обновить"
                            HorizontalAlignment="Stretch" />
                </Grid>

                <TextBlock Foreground="{DynamicResource StatusBrush}"
                           FontWeight="SemiBold"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Margin="24,0,0,0" Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock FontSize="28" FontWeight="Bold" Text="Список блюд" />
                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                           Opacity="0.95"
                           Text="Минимальный сценарий: создание и просмотр состава." />
            </StackPanel>

            <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                    CornerRadius="18"
                    Padding="12">
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Dishes}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:DishListItemViewModel">
                            <Border Background="{DynamicResource CardBackgroundBrush}"
                                    CornerRadius="14"
                                    Margin="0,0,0,12"
                                    Padding="16">
                                <StackPanel Spacing="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Opacity="0.95"
                                                   Text="{Binding Summary}" />
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding Ingredients}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DishIngredientListItemViewModel">
                                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
